{
  "name": "swimbait-api",
  "main": "src/index.js",
  "compatibility_date": "2024-01-01",
  "kv_namespaces": [
    { "binding": "USERS", "id": "REPLACE_WITH_USERS_KV_ID" },
    { "binding": "DESIGNS", "id": "REPLACE_WITH_DESIGNS_KV_ID" }
  ],
  "r2_buckets": [
    { "binding": "THUMBNAILS", "bucket_name": "swimbait-thumbnails" }
  ],
  "routes": [
    { "pattern": "swimbaitdesigner.com/api/*", "zone_name": "swimbaitdesigner.com" }
  ]
}
